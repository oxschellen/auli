# Copy to .env (in this repo root) and fill in. Required vars panic at startup if missing.
# Loaded via dotenv from the CWD upward, so a root .env serves the server run from auli/.

# External LLM (Groq-compatible chat completions) — required
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_API_KEY=your-llm-api-key
LLM_API_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
EMBED_API_MODEL=                     # optional

# Local embeddings (fastembed / BGE-M3, in-process — no external service)
EMBED_CACHE_DIR=./models             # optional (default ./models) — ONNX model cache dir
EMBED_THREADS=16                     # optional (default 16) — ONNX intra-op CPU threads

# Auth / JWT (RS256 — generate a keypair via GET /v1/gen_rsa_keypair) — required
JWT_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_SECRET=change-me
JWT_EXPIRATION_MINUTES=15            # optional (default 15)

# Database (PostgreSQL) — required (auth at boot)
DATABASE_URL=postgres://postgres:password@localhost:5432/aulidb
POSTGRES_USER=postgres               # optional
POSTGRES_PASSWORD=password           # optional

# Vector store (in-process; directory holding the per-collection JSON files)
VECTOR_DB_PATH=./vectors             # optional (default ./vectors)
