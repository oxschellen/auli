# Copy to .env (in this repo root) and fill in. Required vars panic at startup if missing.
# Loaded via dotenv from the CWD upward, so a root .env serves the server run from auli-engine/.

# External LLM (Groq-compatible chat completions) — required
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_API_KEY=your-llm-api-key
LLM_API_MODEL=openai/gpt-oss-120b
EMBED_API_MODEL=                     # optional

# Local embeddings (fastembed / BGE-M3, in-process — no external service)
# EMBED_CACHE_DIR — NÃO defina aqui: os lançadores (start_server.sh, build-packs.sh)
# já apontam o cache para <raiz>/models (caminho absoluto). Quem roda o binário na mão pode exportá-lo.
EMBED_THREADS=24                     # optional (default 16) — ONNX intra-op CPU threads

# Vector packs: the server resolves them from `auli server --packs-dir`, which defaults to
# AULI_DATA_DIR (the registry/prompts root) when omitted — no separate env var.

# Note: the server has no auth and no database. It needs only the LLM + embedding
# settings above — no JWT keys, no DATABASE_URL, no Postgres running.
