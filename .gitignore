# ── Root .gitignore for the auli monorepo ─────────────────────────────────────
# Each subproject (auli-server/, auli-frontend/, auli-collections/) also
# ships its own .gitignore, which git honors. This file covers root-level items
# plus belt-and-suspenders global rules so secrets/artifacts can never slip in.

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Disabled nested git repos (kept locally as .git-bak, excluded here) ────────
**/.git-bak/

# ── Rust build artifacts ──────────────────────────────────────────────────────
target/
**/target/
.cargo/

# ── Node / frontend ───────────────────────────────────────────────────────────
node_modules/
**/node_modules/
dist/
**/dist/
*.tsbuildinfo

# ── Embedding model caches (downloaded, large) ────────────────────────────────
/models/
**/models--*/

# ── Generated vector packs & runtime state ────────────────────────────────────
auli-server/packs/
**/vectors/
**/logs/

# ── Scraper cache (lives at data/<id>/raw/cache/) ─────────────────────────────
**/data/*/raw/cache/

# ── Local notes / scratch ─────────────────────────────────────────────────────
notas.txt
notes.txt
web_config.txt

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
*.swp
*~

# ── Claude Code: commit the shared settings.json (like auli-collections/.claude/), but keep
#    the per-user settings.local.json out of git ──
/.claude/settings.local.json

# Data integration (root data/): dados GERADOS ficam fora do git; SÓ o source-of-truth AUTORADO é
# versionado — `registry.toml`, `prompts/`, e os autorados em `<id>/ref/` (conteudo_site_tree, notas,
# portal-pareceres do RS). Todo o resto é reconstruído pelo pipeline: scraper → `auli-collections` →
# `auli update` / `scripts/build-packs.sh` (packs) e `scripts/build-frontend-public.sh` (public/).
data/*/raw/
data/*/raw/cache/
data/*/packs/
# Snapshots do scraper (intermediários que alimentam o `auli-collections`).
data/*/*-snapshot.json
# Intermediários em ref/ (saída regenerável, ex.: <id>-pareceres-temp.txt) — código, não dado.
data/*/ref/*-temp.txt
# Portais de pareceres regeneráveis (cópia do temp do scraper), diferente do RS que é autorado.
data/sc/ref/sc-portal-pareceres.txt
data/sp/ref/sp-portal-pareceres.txt
/*.patch
