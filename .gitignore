# ── Root .gitignore for the auli monorepo ─────────────────────────────────────
# Each subproject (auli-engine/, auli-frontend/, auli-collections/) also
# ships its own .gitignore, which git honors. (The pre-refactor auli-server/ baseline was
# removed from the tree — see the baseline-auli-server tag.) This file covers root-level items
# plus belt-and-suspenders global rules so secrets/artifacts can never slip in.

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Disabled nested git repos (kept locally as .git-bak, excluded here) ────────
**/.git-bak/

# ── Rust build artifacts ──────────────────────────────────────────────────────
target/
**/target/
.cargo/

# ── Node / frontend ───────────────────────────────────────────────────────────
node_modules/
**/node_modules/
dist/
**/dist/
*.tsbuildinfo

# ── Embedding model caches (downloaded, large) ────────────────────────────────
/models/
**/models--*/
auli-engine/models/

# ── Generated vector packs & runtime state ────────────────────────────────────
auli-engine/packs/
**/vectors/
**/logs/

# ── Scraper cache ─────────────────────────────────────────────────────────────
**/data/*/cache/

# ── Local notes / scratch ─────────────────────────────────────────────────────
notas.txt
notes.txt
web_config.txt

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
*.swp
*~

# Data integration (root data/): generated artifacts ignored; prompts/ and <id>/ref/ are versioned
data/*/raw/
data/*/cache/
data/*/packs/
/*.patch
